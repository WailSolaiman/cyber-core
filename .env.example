# Public Mux playback ID (from Mux dashboard). Hero uses https://player.mux.com/{ID}?...
# Leave empty to use the bundled demo asset from stitch-cc-design.
VITE_MUX_PLAYBACK_ID=

# Optional: extra Mux Player query params (no leading ?). Merged with defaults; autoplay=muted, loop, muted are always set for the hero.
# VITE_MUX_PLAYER_PARAMS=metadata-video-title=My+Title&video-title=My+Title
